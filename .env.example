# Crypto X-Ray — Environment Variables
# Copy this to .env and fill in your API keys

# CoinGecko (free tier works, pro key optional for higher limits)
VITE_COINGECKO_API_KEY=

# Tokenomist.ai (paid — unlock/vesting data)
VITE_TOKENOMIST_API_KEY=

# Token Terminal (paid — fundamentals data)
VITE_TOKEN_TERMINAL_API_KEY=

# Etherscan (free tier: 5 calls/sec)
VITE_ETHERSCAN_API_KEY=

# Basescan
VITE_BASESCAN_API_KEY=

# Arbiscan
VITE_ARBISCAN_API_KEY=

# Solscan (pro API for Solana data)
VITE_SOLSCAN_API_KEY=

# Helius (Solana RPC + DAS API)
VITE_HELIUS_API_KEY=

# Debank (wallet portfolio data)
VITE_DEBANK_API_KEY=
